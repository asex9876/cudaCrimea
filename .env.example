# ========================================
# ВАЖНО: Скопируйте этот файл в .env и заполните своими значениями!
# cp .env.example .env
# ========================================

# Runtime
ENV=production  # dev или production
APP_NAME=Куда пойти: Крым/Севастополь
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Telegram (получить на https://my.telegram.org)
BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION=
TG_CHANNELS=@YourChannel

# Datastores
# ВАЖНО: На проде смените пароль postgres!
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_THIS_PASSWORD@db:5432/cudacrimea
REDIS_URL=redis://redis:6379/0

# Observability (опционально)
SENTRY_DSN=

# LLM (AI Mediator / OpenAI-compatible)
AI_MEDIATOR_API_KEY=your_api_key_here
AI_MEDIATOR_BASE_URL=https://api.ai-mediator.ru/v1
LLM_AUTH_HEADER=Authorization
LLM_AUTH_SCHEME=Bearer
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_EXTRACTOR=gpt-4o-mini
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini
OPENAI_MODEL_SUMMARIZER=gpt-4o-mini

# Places providers (опционально)
TWO_GIS_API_KEY=
YANDEX_MAPS_API_KEY=

# Ranking weights
W_TIME=0.3
W_GEO=0.3
W_INTEREST=0.2
W_SOURCE=0.1
W_POP=0.1
W_OPEN=0.0

# Admin
# ВАЖНО: На проде смените на безопасные значения!
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
ADMIN_TOKEN=
ADMIN_SECRET=CHANGE_THIS_SECRET_MIN_32_CHARS

# Database password (для docker-compose)
DB_PASSWORD=CHANGE_THIS_PASSWORD
